{
  "name": "rssp.js",
  "version": "1.5.2",
  "description": "R-SSP JavaScript Client SDK",
  "main": "index.js",
  "repository": "https://github.rakops.com/gatd/rssp.js",
  "private": true,
  "scripts": {
    "analyze": "TS_NODE_PROJECT=tsconfig.webpack.json USE_ANALYZE=true webpack --mode production",
    "analyze-watch": "TS_NODE_PROJECT=tsconfig.webpack.json USE_ANALYZE=true webpack --mode production --watch",
    "serve": "TS_NODE_PROJECT=tsconfig.webpack.json USE_LOCAL_SERVER=true webpack-dev-server --watch --mode development --config development.config.ts",
    "serve-mock": "TS_NODE_PROJECT=tsconfig.webpack.json USE_LOCAL_SERVER=true IS_CONSOLE_LOG=true webpack-dev-server --mode development --config development.config.ts",
    "build": "TS_NODE_PROJECT=tsconfig.webpack.json webpack --mode production",
    "build-dev": "TS_NODE_PROJECT=tsconfig.webpack.json webpack --mode development",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint-fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "unit-test": "TS_NODE_PROJECT=tsconfig.webpack.json jest --testRegex=\\.test\\.ts$  --maxWorkers=1",
    "e2e-test": "start-server-and-test start-test-server http://bs-local.com:3111 cypress:run",
    "ci-test": "npm run unit-test && npm run e2e-test",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "start-test-server": "TS_NODE_PROJECT=tsconfig.webpack.json USE_LOCAL_SERVER=true webpack-dev-server --mode development --config development.config.ts"
  },
  "dependencies": {
    "@types/js-cookie": "^3.0.4",
    "@types/ua-parser-js": "^0.7.37",
    "@types/uuid": "^9.0.4",
    "@types/whatwg-fetch": "^0.0.33",
    "crypto-js": "4.1.1",
    "es6-promise": "^4.2.8",
    "js-cookie": "^3.0.5",
    "preact": "^10.18.1",
    "preact-compat": "^3.19.0",
    "rxjs": "^7.8.1",
    "ua-parser-js": "1.0.36",
    "url-search-params-polyfill": "^8.2.5",
    "uuid": "^9.0.1",
    "vast-client": "^3.2.0",
    "whatwg-fetch": "^3.6.19"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.22.20",
    "@testing-library/dom": "^9.3.3",
    "@types/crypto-js": "^4.1.2",
    "@types/doubleclick-gpt": "^2019111201.0.4",
    "@types/html-webpack-plugin": "^3.2.7",
    "@types/jest": "^29.5.5",
    "@types/jest-dev-server": "^5.0.1",
    "@types/node": "^20.8.2",
    "@types/rewire": "^2.5.28",
    "@types/selenium-webdriver": "^4.1.17",
    "@types/vast-client": "^3.0.2",
    "@types/webpack": "^5.28.3",
    "@types/webpack-bundle-analyzer": "^4.6.1",
    "@types/webpack-dev-server": "^4.7.2",
    "@typescript-eslint/eslint-plugin": "6.7.4",
    "@typescript-eslint/parser": "6.7.4",
    "babel-core": "^6.26.3",
    "babel-loader": "^9.1.3",
    "babel-preset-env": "^1.7.0",
    "browserstack-local": "^1.5.5",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "6.8.1",
    "cypress": "^13.13.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-compat": "^4.2.0",
    "eslint-plugin-deprecation": "^2.0.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jest": "^27.4.2",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.2",
    "html-webpack-plugin": "5.5.3",
    "jest": "^29.7.0",
    "jest-dev-server": "^9.0.1",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-transform-stub": "^2.0.0",
